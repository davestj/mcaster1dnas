#!/bin/sh
# Mcaster1DNAS — prerm script for Debian/Ubuntu .deb package
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop the service before removal
        if [ -d /run/systemd/system ]; then
            systemctl stop mcaster1-dnas.service 2>/dev/null || true
            systemctl disable mcaster1-dnas.service 2>/dev/null || true
        fi
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
